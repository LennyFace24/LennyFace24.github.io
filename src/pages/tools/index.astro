---
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { Icon } from "astro-icon/components";
import { i18n } from "@i18n/translation";
import I18nKey from "@i18n/i18nKey";
---

<MainGridLayout title="小工具" description="实用小工具集合">

<div class="card-base p-6 onload-animation">
    <div class="flex items-center gap-3 mb-6">
        <Icon name="material-symbols:build-circle" class="text-2xl text-[var(--primary)]" />
        <h1 class="text-2xl font-bold text-90">小工具</h1>
    </div>

    <p class="text-75 mb-8">实用的小工具集合，帮助你更高效地完成工作。</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <!-- 封面设计器 -->
        <a href="/tools/cover-generator/" class="group card-base p-5 hover:scale-[1.02] active:scale-[0.98] transition-all">
            <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-[var(--enter-btn-bg)] group-hover:bg-[var(--primary)] transition-colors">
                    <Icon name="material-symbols:image-outline" class="text-2xl text-[var(--primary)] group-hover:text-white transition-colors" />
                </div>
                <div class="flex-1">
                    <h3 class="font-semibold text-90 group-hover:text-[var(--primary)] transition-colors mb-1">封面设计器</h3>
                    <p class="text-sm text-50">在线设计精美的封面图，支持多种比例、图标、文字自定义。</p>
                </div>
                <Icon name="material-symbols:chevron-right-rounded" class="text-xl text-30 group-hover:text-[var(--primary)] transition-colors mt-1" />
            </div>
        </a>

        <!-- 吃掉小鹿乃 -->
        <a href="/tools/eatkano/" class="group card-base p-5 hover:scale-[1.02] active:scale-[0.98] transition-all">
            <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-[var(--enter-btn-bg)] group-hover:bg-[var(--primary)] transition-colors">
                    <Icon name="material-symbols:sports-esports-outline" class="text-2xl text-[var(--primary)] group-hover:text-white transition-colors" />
                </div>
                <div class="flex-1">
                    <h3 class="font-semibold text-90 group-hover:text-[var(--primary)] transition-colors mb-1">吃掉小鹿乃</h3>
                    <p class="text-sm text-50">音游小游戏，点击方块得分，挑战每日排行榜！</p>
                </div>
                <Icon name="material-symbols:chevron-right-rounded" class="text-xl text-30 group-hover:text-[var(--primary)] transition-colors mt-1" />
            </div>
        </a>

        <!-- 编码解码工具 -->
        <a href="/tools/encoders/" class="group card-base p-5 hover:scale-[1.02] active:scale-[0.98] transition-all">
            <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-[var(--enter-btn-bg)] group-hover:bg-[var(--primary)] transition-colors">
                    <Icon name="material-symbols:code-rounded" class="text-2xl text-[var(--primary)] group-hover:text-white transition-colors" />
                </div>
                <div class="flex-1">
                    <h3 class="font-semibold text-90 group-hover:text-[var(--primary)] transition-colors mb-1">编码解码工具</h3>
                    <p class="text-sm text-50">Base64、URL、Hex（十六进制）、HTML 实体 编码解码互转。</p>
                </div>
                <Icon name="material-symbols:chevron-right-rounded" class="text-xl text-30 group-hover:text-[var(--primary)] transition-colors mt-1" />
            </div>
        </a>

        <!-- 哈希计算器 -->
        <a href="/tools/hash/" class="group card-base p-5 hover:scale-[1.02] active:scale-[0.98] transition-all">
            <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-[var(--enter-btn-bg)] group-hover:bg-[var(--primary)] transition-colors">
                    <Icon name="material-symbols:hash-rounded" class="text-2xl text-[var(--primary)] group-hover:text-white transition-colors" />
                </div>
                <div class="flex-1">
                    <h3 class="font-semibold text-90 group-hover:text-[var(--primary)] transition-colors mb-1">哈希计算器</h3>
                    <p class="text-sm text-50">MD5 / SHA-1 / SHA-256 / SHA-384 / SHA-512 哈希计算，支持文本与文件。</p>
                </div>
                <Icon name="material-symbols:chevron-right-rounded" class="text-xl text-30 group-hover:text-[var(--primary)] transition-colors mt-1" />
            </div>
        </a>

        <!-- AES 加解密 -->
        <a href="/tools/aes/" class="group card-base p-5 hover:scale-[1.02] active:scale-[0.98] transition-all">
            <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-[var(--enter-btn-bg)] group-hover:bg-[var(--primary)] transition-colors">
                    <Icon name="material-symbols:enhanced-encryption-rounded" class="text-2xl text-[var(--primary)] group-hover:text-white transition-colors" />
                </div>
                <div class="flex-1">
                    <h3 class="font-semibold text-90 group-hover:text-[var(--primary)] transition-colors mb-1">AES 加解密</h3>
                    <p class="text-sm text-50">基于 AES-GCM 与 PBKDF2 的对称加密解密，支持 128/192/256 位密钥。</p>
                </div>
                <Icon name="material-symbols:chevron-right-rounded" class="text-xl text-30 group-hover:text-[var(--primary)] transition-colors mt-1" />
            </div>
        </a>

        <!-- JWT 解码器 -->
        <a href="/tools/jwt/" class="group card-base p-5 hover:scale-[1.02] active:scale-[0.98] transition-all">
            <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-[var(--enter-btn-bg)] group-hover:bg-[var(--primary)] transition-colors">
                    <Icon name="material-symbols:key-vertical" class="text-2xl text-[var(--primary)] group-hover:text-white transition-colors" />
                </div>
                <div class="flex-1">
                    <h3 class="font-semibold text-90 group-hover:text-[var(--primary)] transition-colors mb-1">JWT 解码器</h3>
                    <p class="text-sm text-50">解析 JWT 的 Header 与 Payload，自动识别时间声明，纯客户端解析。</p>
                </div>
                <Icon name="material-symbols:chevron-right-rounded" class="text-xl text-30 group-hover:text-[var(--primary)] transition-colors mt-1" />
            </div>
        </a>
    </div>
</div>

</MainGridLayout>
