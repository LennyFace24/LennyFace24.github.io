---
// EatKano 游戏页面 — 原版游戏 + 排行榜插件
// 不修改任何原始游戏文件，排行榜通过注入方式附加
import { readFileSync } from "node:fs";

const originalHtml = readFileSync("public/tools/eatkano/index.html", "utf-8");

const leaderboardHtml = `
<!-- ====== Leaderboard Plugin ====== -->
<style>
.lb-nav-btn {
  position: fixed; top: 0.8rem; right: 0.8rem; z-index: 12;
  background: rgba(255,255,255,0.15); backdrop-filter: blur(4px);
  border: 1px solid rgba(255,255,255,0.2); border-radius: 2rem;
  padding: 0.4rem 1rem; color: #fff; font-weight: 700; font-size: 0.85rem;
  cursor: pointer; display: flex; align-items: center; gap: 0.4rem;
  transition: background 0.2s; text-decoration: none;
}
.lb-nav-btn:hover { background: rgba(255,255,255,0.25); }
.lb-back-btn {
  position: fixed; top: 0.8rem; left: 0.8rem; z-index: 12;
  background: rgba(255,255,255,0.15); backdrop-filter: blur(4px);
  border: 1px solid rgba(255,255,255,0.2); border-radius: 2rem;
  padding: 0.4rem 1rem; color: #fff; font-weight: 600; font-size: 0.85rem;
  cursor: pointer; transition: background 0.2s; text-decoration: none;
}
.lb-back-btn:hover { background: rgba(255,255,255,0.25); color: #fff; }
.lb-overlay {
  display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 100; background: rgba(0,0,0,0.85);
  justify-content: center; align-items: center; overflow-y: auto; padding: 1rem;
}
.lb-overlay.active { display: flex; }
.lb-panel {
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 1.5rem; padding: 1.5rem; max-width: 500px; width: 100%;
  max-height: 90vh; overflow-y: auto; box-shadow: 0 20px 60px rgba(0,0,0,0.5);
  color: #fff;
}
.lb-panel h2 { text-align: center; font-size: 1.6rem; font-weight: 800; margin-bottom: 0.25rem; text-shadow: 0 2px 4px rgba(0,0,0,0.3); }
.lb-panel .lb-date { text-align: center; font-size: 0.85rem; opacity: 0.75; margin-bottom: 1rem; }
.lb-entry { display: flex; align-items: center; padding: 0.6rem 0.8rem; margin-bottom: 0.4rem; border-radius: 0.8rem; background: rgba(255,255,255,0.1); backdrop-filter: blur(4px); }
.lb-entry.is-player { background: rgba(255,215,0,0.2); border: 1px solid rgba(255,215,0,0.4); }
.lb-entry .rank { width: 2.2rem; font-weight: 800; font-size: 1.1rem; text-align: center; flex-shrink: 0; }
.lb-entry .rank.gold { color: #ffd700; }
.lb-entry .rank.silver { color: #c0c0c0; }
.lb-entry .rank.bronze { color: #cd7f32; }
.lb-entry .name { flex: 1; font-weight: 600; font-size: 1rem; margin-left: 0.5rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.lb-entry .score { font-weight: 800; font-size: 1.1rem; flex-shrink: 0; }
.lb-empty { text-align: center; padding: 2rem; opacity: 0.7; font-size: 1rem; }
.lb-player-info { text-align: center; padding: 0.6rem; margin-bottom: 0.8rem; border-radius: 0.8rem; background: rgba(255,255,255,0.08); font-size: 0.9rem; }
.lb-player-info strong { color: #ffd700; }
.lb-close-btn { display: block; width: 100%; padding: 0.7rem; margin-top: 0.8rem; border: none; border-radius: 0.8rem; background: rgba(255,255,255,0.2); color: #fff; font-weight: 700; font-size: 1rem; cursor: pointer; }
.lb-close-btn:hover { background: rgba(255,255,255,0.3); }
.lb-name-overlay {
  display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 99; background: rgba(0,0,0,0.8); justify-content: center; align-items: center;
}
.lb-name-overlay.active { display: flex; }
.lb-name-panel { background: #fff; border-radius: 1.5rem; padding: 2rem; max-width: 380px; width: 90%; text-align: center; }
.lb-name-panel h3 { font-weight: 800; font-size: 1.4rem; margin-bottom: 0.5rem; }
.lb-name-panel p { color: #666; font-size: 0.9rem; margin-bottom: 1.2rem; }
.lb-name-panel input { width: 100%; padding: 0.8rem 1rem; border: 2px solid #e0e0e0; border-radius: 0.8rem; font-size: 1rem; text-align: center; outline: none; box-sizing: border-box; }
.lb-name-panel input:focus { border-color: #667eea; }
.lb-name-panel .lb-name-submit { display: block; width: 100%; padding: 0.8rem; margin-top: 1rem; border: none; border-radius: 0.8rem; background: linear-gradient(135deg, #667eea, #764ba2); color: #fff; font-weight: 700; font-size: 1rem; cursor: pointer; }
.lb-name-panel .lb-name-skip { display: inline-block; margin-top: 0.8rem; color: #999; font-size: 0.85rem; cursor: pointer; text-decoration: underline; }
</style>

<a href="/tools/" class="lb-back-btn">← 返回工具</a>
<button class="lb-nav-btn" onclick="window.showLeaderboard()">🏆 排行</button>

<div class="lb-overlay" id="lbOverlay">
  <div class="lb-panel">
    <h2>🏆 排行榜</h2>
    <div class="lb-date" id="lbDate"></div>
    <div class="lb-player-info" id="lbPlayerInfo" style="display:none"></div>
    <div id="lbEntries"></div>
    <button class="lb-close-btn" onclick="document.getElementById('lbOverlay').classList.remove('active')">✕ 关闭</button>
  </div>
</div>

<div class="lb-name-overlay" id="lbNameOverlay">
  <div class="lb-name-panel">
    <h3>🏆 排行榜</h3>
    <p>填写名称参与今日排行</p>
    <input type="text" id="lbNameInput" maxlength="20" placeholder="输入你的名称..." autocomplete="off" />
    <button class="lb-name-submit" onclick="window.submitName()">提交名称</button>
    <div class="lb-name-skip" onclick="document.getElementById('lbNameOverlay').style.display='none'">跳过</div>
  </div>
</div>

<script>
// ====== Leaderboard System (cookie + localStorage, no PHP needed) ======
(function() {
function setCookie(n, v, days) {
  var d = new Date();
  d.setTime(d.getTime() + days * 864e5);
  document.cookie = n + '=' + encodeURIComponent(v) + '; expires=' + d.toUTCString() + '; path=/';
}
function getCookie(n) {
  var parts = document.cookie.split('; ');
  for (var i = 0; i < parts.length; i++) {
    var p = parts[i].split('=');
    if (p[0] === n) return decodeURIComponent(p.slice(1).join('='));
  }
  return null;
}
function getToday() {
  var d = new Date();
  return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0');
}
function getLBKey() { return 'eatkano_rank_' + getToday(); }
function getEntries() {
  try { return JSON.parse(localStorage.getItem(getLBKey())) || []; } catch(e) { return []; }
}
function saveEntries(entries) {
  localStorage.setItem(getLBKey(), JSON.stringify(entries));
}

window.Leaderboard = {
  getPlayerName: function() { return getCookie('eatkano_player'); },
  setPlayerName: function(name) {
    var clean = name.trim().slice(0, 20).replace(/[<>"'&]/g, '');
    if (clean) setCookie('eatkano_player', clean, 365);
    return clean;
  },
  submitScore: function(score) {
    var name = this.getPlayerName();
    if (!name) return false;
    var entries = getEntries();
    var existing = null;
    for (var i = 0; i < entries.length; i++) {
      if (entries[i].name === name) { existing = entries[i]; break; }
    }
    if (existing) {
      if (score > existing.score) existing.score = score;
      existing.attempts = (existing.attempts || 1) + 1;
    } else {
      entries.push({ name: name, score: score, attempts: 1 });
    }
    entries.sort(function(a, b) { return b.score - a.score; });
    if (entries.length > 50) entries.length = 50;
    saveEntries(entries);
    return true;
  },
  getEntries: getEntries,
  getToday: getToday,
  getPlayerRank: function() {
    var name = this.getPlayerName();
    if (!name) return -1;
    var entries = getEntries();
    for (var i = 0; i < entries.length; i++) {
      if (entries[i].name === name) return i + 1;
    }
    return -1;
  },
  getPlayerBest: function() {
    var name = this.getPlayerName();
    if (!name) return 0;
    var entries = getEntries();
    for (var i = 0; i < entries.length; i++) {
      if (entries[i].name === name) return entries[i].score;
    }
    return 0;
  }
};

// Hook into game over — auto submit score
var origGameOver = window.gameOver;
if (origGameOver) {
  window.gameOver = function() {
    origGameOver();
    if (typeof window.mode !== 'undefined' && window.mode === 1 && window.Leaderboard.getPlayerName()) {
      window.Leaderboard.submitScore(typeof window._gameScore !== 'undefined' ? window._gameScore : 0);
    }
  };
}
})();

// ====== Name input ======
window.submitName = function() {
  var input = document.getElementById('lbNameInput');
  if (window.Leaderboard.setPlayerName(input.value)) {
    document.getElementById('lbNameOverlay').style.display = 'none';
  } else {
    input.focus();
    input.select();
  }
};

// ====== Leaderboard panel ======
window.showLeaderboard = function() {
  var overlay = document.getElementById('lbOverlay');
  var entries = window.Leaderboard.getEntries();
  var container = document.getElementById('lbEntries');
  var playerInfo = document.getElementById('lbPlayerInfo');
  document.getElementById('lbDate').textContent = window.Leaderboard.getToday();

  var playerName = window.Leaderboard.getPlayerName();
  if (playerName) {
    var rank = window.Leaderboard.getPlayerRank();
    var best = window.Leaderboard.getPlayerBest();
    playerInfo.style.display = 'block';
    if (rank > 0) {
      playerInfo.innerHTML = '<strong>' + playerName + '</strong> — 排名 #' + rank + ' | 最佳 ' + best;
    } else {
      playerInfo.innerHTML = '<strong>' + playerName + '</strong> — 暂无排行记录';
    }
  } else {
    playerInfo.style.display = 'none';
  }

  if (entries.length === 0) {
    container.innerHTML = '<div class="lb-empty">暂无排行数据</div>';
  } else {
    var html = '';
    for (var i = 0; i < entries.length; i++) {
      var e = entries[i];
      var medal = i === 0 ? '&#x1F947;' : i === 1 ? '&#x1F948;' : i === 2 ? '&#x1F949;' : '#' + (i + 1);
      var cls = i === 0 ? 'gold' : i === 1 ? 'silver' : i === 2 ? 'bronze' : '';
      var isPlayer = playerName && e.name === playerName;
      html += '<div class="lb-entry' + (isPlayer ? ' is-player' : '') + '">'
        + '<div class="rank ' + cls + '">' + medal + '</div>'
        + '<div class="name">' + e.name + '</div>'
        + '<div class="score">' + e.score + '</div></div>';
    }
    container.innerHTML = html;
  }
  overlay.classList.add('active');
};

// Name prompt on first visit
if (!window.Leaderboard.getPlayerName()) {
  (function() {
    var check = function() {
      if (document.getElementById('lbNameOverlay')) {
        document.getElementById('lbNameOverlay').style.display = 'flex';
      } else {
        setTimeout(check, 200);
      }
    };
    setTimeout(check, 800);
  })();
}

// Name prompt after replay if no name
var origReplay = window.replayBtn;
if (origReplay) {
  window.replayBtn = function() {
    origReplay();
    setTimeout(function() {
      if (!window.Leaderboard.getPlayerName()) {
        document.getElementById('lbNameOverlay').style.display = 'flex';
      }
    }, 600);
  };
}

// Enter key on name input
document.addEventListener('DOMContentLoaded', function() {
  var input = document.getElementById('lbNameInput');
  if (input) {
    input.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') window.submitName();
    });
  }
});
</script>
<!-- ====== End Leaderboard Plugin ====== -->
`;

const finalHtml = originalHtml.replace("</body>", leaderboardHtml + "\n</body>");
---

<Fragment set:html={finalHtml} />